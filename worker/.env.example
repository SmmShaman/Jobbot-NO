# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Worker Identity (for multi-worker locking)
# Each worker instance must have a unique ID
WORKER_ID=dev-pc
WORKER_LOCATION=dev-pc

# Skyvern Configuration
# Primary: HuggingFace Space (cloud, always-on)
# Fallback: local Docker (when HF Space is down)
SKYVERN_PRIMARY_URL=https://goldcc-skyvern.hf.space
SKYVERN_FALLBACK_URL=http://localhost:8000
SKYVERN_API_KEY=your-skyvern-api-key

# HuggingFace (for private Space authentication)
HF_TOKEN=your-hf-token

# FINN.no Login Credentials (Required for Enkel Søknad)
FINN_EMAIL=your-finn-email@example.com
FINN_PASSWORD=your-finn-password

# Telegram Bots
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_TECH_BOT_TOKEN=your-tech-bot-token

# Gemini AI (for MetaClaw skill generation)
GEMINI_API_KEY=your-gemini-api-key

# Default email for registration on recruitment sites (optional)
DEFAULT_REGISTRATION_EMAIL=your-email@example.com
